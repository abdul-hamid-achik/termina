{
  "name": "termina",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A text-based multiplayer MOBA played through a terminal-inspired browser UI",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest",
    "test:unit": "vitest run --project unit",
    "test:components": "vitest run --project components",
    "test:integration": "vitest run --project integration",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:e2e:ui": "playwright test --config playwright.config.ts --ui",
    "test:e2e:headed": "playwright test --config playwright.config.ts --headed",
    "test:api": "npx hitspec run collections/",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "knip": "knip",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@pinia/nuxt": "^0.9.0",
    "consola": "^3.4.2",
    "drizzle-orm": "^0.38.4",
    "effect": "^3.21.3",
    "ioredis": "^5.11.1",
    "nuxt": "^3.21.8",
    "nuxt-auth-utils": "^0.5.29",
    "pinia": "^2.3.1",
    "postgres": "^3.4.9",
    "reka-ui": "^2.9.10",
    "vue": "^3.5.38",
    "vue-router": "^4.6.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/eslint": "^0.7.6",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@playwright/test": "^1.60.0",
    "@vue/test-utils": "^2.4.11",
    "drizzle-kit": "^0.30.6",
    "eslint": "^9.39.4",
    "happy-dom": "^15.11.7",
    "knip": "^5.88.1",
    "lefthook": "^2.1.9",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "@vitejs/plugin-vue": "^5.2.4",
    "ws": "^8.21.0"
  }
}
