{
  "name": "termina",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A text-based multiplayer MOBA played through a terminal-inspired browser UI",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest",
    "test:unit": "vitest run --project unit",
    "test:components": "vitest run --project components",
    "test:integration": "vitest run --project integration",
    "test:e2e": "cairn run tests/e2e/flows --config tests/e2e/cairntrace.config.yml --cold-start",
    "test:e2e:ci": "cairn run tests/e2e/flows --config tests/e2e/cairntrace.config.yml --cold-start --junit --stamp-if-green",
    "test:api": "npx hitspec run collections/",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "knip": "knip",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.1.0",
    "@pinia/nuxt": "^0.9.0",
    "consola": "^3.4.2",
    "drizzle-orm": "^0.45.0",
    "effect": "^3.12.0",
    "ioredis": "^5.4.0",
    "nuxt": "^3.21.8",
    "nuxt-auth-utils": "^0.5.0",
    "pinia": "^2.3.0",
    "postgres": "^3.4.0",
    "reka-ui": "^2.1.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "^6.12.0",
    "@vue/test-utils": "^2.4.6",
    "drizzle-kit": "^0.31.0",
    "happy-dom": "^20.10.0",
    "knip": "^6.16.0",
    "lefthook": "^2.1.1",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^6.0.0",
    "vitest": "^2.1.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "vue-tsc": "^3.2.5",
    "ws": "^8.19.0"
  },
  "overrides": {
    "@nuxt/kit": "3.21.8",
    "@nuxt/schema": "3.21.8"
  }
}
