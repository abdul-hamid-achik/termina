# ── Local secrets via tvault (recommended) ────────────────────────
# Instead of a plaintext .env, store these in tvault (keyed by the SAME names
# below) and inject them per-process — nothing on disk, nothing in shell history:
#   tvault projects create termina && tvault use termina
#   tvault import .env                 # or: tvault set NUXT_SESSION_PASSWORD …
#   tvault run -- bun run dev          # dev server with secrets injected
#   tvault run -- pulumi up            # (in infra/) deploy with secrets injected
# See infra/README.md for the full secrets + deploy runbook. The plain .env below
# still works for quick local setup (copy to .env and fill in).

# Database
DATABASE_URL=postgresql://termina:termina@localhost:5433/termina
NUXT_DATABASE_URL=postgresql://termina:termina@localhost:5433/termina

# Redis
REDIS_URL=redis://localhost:6380
NUXT_REDIS_URL=redis://localhost:6380

# Auth — session secret must be at least 32 characters
NUXT_SESSION_PASSWORD=change-me-to-a-random-string-at-least-32-chars

# OAuth — register apps at GitHub/Discord developer portals
NUXT_OAUTH_GITHUB_CLIENT_ID=
NUXT_OAUTH_GITHUB_CLIENT_SECRET=
NUXT_OAUTH_DISCORD_CLIENT_ID=
NUXT_OAUTH_DISCORD_CLIENT_SECRET=

# ── Vercel + DigitalOcean split deploy ────────────────────────────
# Set these on the Vercel frontend (NOT on DO) so the SPA knows where the
# WS server + API live. Empty = same-origin (dev + single-instance DO).
# Example: NUXT_PUBLIC_WS_URL=wss://ws.termina.xyz
#          NUXT_PUBLIC_API_URL=https://ws.termina.xyz
NUXT_PUBLIC_WS_URL=
NUXT_PUBLIC_API_URL=

# CORS allow-list for the DigitalOcean API server: comma-separated browser
# Origins allowed credentialed cross-origin access to /api/ (set to your Vercel
# app URL in prod, e.g. https://termina.vercel.app). Empty = echo the request
# origin (dev / same-origin). Set this on the DO side, NOT Vercel.
NUXT_CORS_ALLOWED_ORIGINS=

# Server bind (DO App Platform sets these automatically; useful for Docker)
HOST=0.0.0.0
PORT=3000

# Dev/e2e test hooks — NEVER set in production. Bypasses auth + seeds games.
# TERMINA_TEST_HOOKS=1
# TERMINA_DISABLE_RATE_LIMIT=1
# TERMINA_TEST_FAST_GAME=8
