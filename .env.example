# Database
DATABASE_URL=postgresql://termina:termina@localhost:5433/termina
NUXT_DATABASE_URL=postgresql://termina:termina@localhost:5433/termina

# Redis
REDIS_URL=redis://localhost:6380
NUXT_REDIS_URL=redis://localhost:6380

# Auth — session secret must be at least 32 characters
NUXT_SESSION_PASSWORD=change-me-to-a-random-string-at-least-32-chars

# OAuth — register apps at GitHub/Discord developer portals
NUXT_OAUTH_GITHUB_CLIENT_ID=
NUXT_OAUTH_GITHUB_CLIENT_SECRET=
NUXT_OAUTH_DISCORD_CLIENT_ID=
NUXT_OAUTH_DISCORD_CLIENT_SECRET=

# ── Vercel + DigitalOcean split deploy ────────────────────────────
# Set these on the Vercel frontend (NOT on DO) so the SPA knows where the
# WS server + API live. Empty = same-origin (dev + single-instance DO).
# Example: NUXT_PUBLIC_WS_URL=wss://ws.termina.xyz
#          NUXT_PUBLIC_API_URL=https://ws.termina.xyz
NUXT_PUBLIC_WS_URL=
NUXT_PUBLIC_API_URL=

# Server bind (DO App Platform sets these automatically; useful for Docker)
HOST=0.0.0.0
PORT=3000

# Dev/e2e test hooks — NEVER set in production. Bypasses auth + seeds games.
# TERMINA_TEST_HOOKS=1
# TERMINA_DISABLE_RATE_LIMIT=1
# TERMINA_TEST_FAST_GAME=8
