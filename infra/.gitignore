# Pulumi TypeScript build output
/bin/

# Dependencies (this project has its own, isolated from the app root)
node_modules/

# Never commit a plaintext export of secrets
*.env
.env
.env.*
# …except the recipient-sealed (v2) deploy secrets, which ARE commit-safe:
# ciphertext sealed to the `ci` tvault identity, decrypted in CI with
# TVAULT_IDENTITY_KEY. Create with: tvault -p termina seal --recipient <ci-pub> --out infra/.env.encrypted
!.env.encrypted
