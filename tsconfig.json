{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false
  },
  // Overrides the generated exclude (extends replaces, not merges). Keeps the
  // generated entries and additionally drops tests/scripts from the build
  // typecheck — vitest owns those.
  "exclude": ["dist", ".data", ".output", "node_modules", "tests/**", "scripts/**", "infra"]
}
